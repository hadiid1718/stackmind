{
  "name": "stackmind-auth-service",
  "version": "1.0.0",
  "description": "Authentication, Organisation, and Ingestion microservice for Stackmind",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node --watch src/server.js",
    "dev": "node src/server.js",
    "dev:docker": "bash ./scripts/dev.sh ",
    "prod:docker": "bash ./scripts/prod.sh ",
    "gateway:start": "node --watch src/gateway.server.js",
    "gateway:dev": "node src/gateway.server.js",
    "gateway:smoke": "node src/gateway/gateway.smoke.js",
    "db:setup": "node scripts/db.setup.js",
    "ingestion:smoke": "node src/ingestion/ingestion.smoke.js",
    "graph:smoke": "node src/graph/graph.smoke.js",
    "ai:smoke": "node src/ai/ai.smoke.js",
    "notifications:smoke": "node src/notifications/notifications.smoke.js",
    "billing:smoke": "node src/billing/billing.smoke.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.8.2",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.2.0",
    "http-proxy-middleware": "^3.0.5",
    "ioredis": "^5.6.1",
    "jest": "^30.3.0",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "mongoose": "^8.5.4",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.5",
    "openai": "^4.104.0",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "socket.io": "^4.8.1",
    "stripe": "^16.12.0",
    "supertest": "^7.2.2",
    "winston": "^3.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "nodemon": "^3.1.4",
    "prettier": "^3.8.1"
  }
}
